# agent-mesh — example environment file.
# Copy to `.env` (`cp .env.example .env`) and adjust. docker compose reads this
# automatically; for non-Docker dev runs, python-dotenv loads it.

# ───────────────────────────────────────────────────────────────────────────
# Ollama (runs on the HOST, native GPU — not in a container)
# ───────────────────────────────────────────────────────────────────────────
# How the containers reach Ollama. Inside compose this resolves to the host.
# For a bare-metal (no-Docker) dev run, set this to http://localhost:11434.
OLLAMA_URL=http://host.docker.internal:11434

# The reasoning model used by the orchestrator (extract + summarize steps).
CHAT_MODEL=qwen3.5:4b

# Embedding model used by memory-server. nomic-embed-text => 768 dims.
# If you switch models, update EMBED_DIM to match (e.g. all-minilm => 384).
EMBED_MODEL=nomic-embed-text
EMBED_DIM=768

# ───────────────────────────────────────────────────────────────────────────
# Host-only settings (NOT read by containers — used when you start Ollama)
# ───────────────────────────────────────────────────────────────────────────
# Documented here as a reminder; set these in your OS env before launching Ollama.
#   OLLAMA_HOST   makes Ollama listen on all interfaces so containers can reach it.
#   OLLAMA_MODELS points Ollama at your custom model directory.
# Windows (PowerShell, persistent):
#   setx OLLAMA_HOST "0.0.0.0:11434"
#   setx OLLAMA_MODELS "D:\.ollama\models"
# See docs/SETUP.md for the full walkthrough.
# OLLAMA_HOST=0.0.0.0:11434
# OLLAMA_MODELS=D:\.ollama\models

# ───────────────────────────────────────────────────────────────────────────
# Storage paths (inside the containers; backed by named volumes)
# ───────────────────────────────────────────────────────────────────────────
MEMORY_DB=/data/memory.db
MEMORY_INDEX=/data/memory.faiss
AUDIT_DB=/data/audit.db
FILES_DIR=/data

# ───────────────────────────────────────────────────────────────────────────
# Notional cloud-cost price table (prompt-audit-server)
# ───────────────────────────────────────────────────────────────────────────
# Local inference is $0; the audit server also reports what the same token
# counts WOULD have cost on a hypothetical cloud model, for the cost report.
# Edit these to model whichever provider/tier you want to compare against.
PRICE_IN_PER_1M=10.0      # cost per 1,000,000 input tokens
PRICE_OUT_PER_1M=30.0     # cost per 1,000,000 output tokens
PRICE_CURRENCY=USD

# ───────────────────────────────────────────────────────────────────────────
# Service ports (defaults; only change if they collide locally)
# ───────────────────────────────────────────────────────────────────────────
# These are the in-network ports the servers listen on. They are not published
# to the host by default — see docker-compose.yml to expose them for the Inspector.
MEMORY_PORT=8001
FILE_BRIDGE_PORT=8002
AUDIT_PORT=8003
